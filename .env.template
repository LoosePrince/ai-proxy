# Kilo AI Gateway（OpenAI 兼容，见 https://kilo.ai/docs/gateway ）
KILO_API_KEY=
# 可选：覆盖默认 https://api.kilo.ai/api/gateway/v1/chat/completions
# KILO_URL=
# 默认 kilo-auto/free
# KILO_MODEL=kilo-auto/free

# OpenRouter API Key
# 从 https://openrouter.ai/keys 获取你的 API Key
OPENROUTER_API_KEY=

# SiliconFlow API Key
# 从 https://siliconflow.cn 获取你的 API Key
SILICONFLOW_API_KEY=

# SiliconFlow Chat Completions API
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1/chat/completions

# 服务端口号
PORT=3000

# 默认使用的 AI 模型
DEFAULT_MODEL=openrouter/free
